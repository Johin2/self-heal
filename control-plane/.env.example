# Neon Postgres connection (async driver: postgresql+asyncpg://...).
# Use the UNPOOLED url; the app maintains its own pool.
DATABASE_URL=postgresql+asyncpg://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?ssl=require

# Sign sessions + magic-link tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-me

# Resend API key for sending magic-link emails. https://resend.com/
RESEND_API_KEY=re_xxx
RESEND_FROM=auth@self-heal.dev

# Where the dashboard lives (used to build verify links).
DASHBOARD_BASE_URL=http://localhost:3000

# CORS — comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000
