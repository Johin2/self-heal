# Neon Postgres pooled connection string.
# Get this from https://console.neon.tech/ -> your project -> "Connection Details"
# -> select the "Pooled connection" tab.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Control plane backend (FastAPI). Used by the dashboard via server-side
# proxy routes under /api/auth/* and /api/cp/*.
CONTROL_PLANE_URL=http://localhost:8000
